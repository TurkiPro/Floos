# Flutter / Dart
.dart_tool/
.packages
.pub-cache/
.pub/
build/
.flutter-plugins
.flutter-plugins-dependencies

# Generated code (regenerated by build_runner)
lib/**/*.g.dart

# IDE
.idea/
.vscode/
*.iml

# OS
.DS_Store

# Screenshot output (produced by the Screenshots workflow, downloaded as an artifact)
screenshots/

# Signing secrets — NEVER commit these. CI recreates them from repo secrets.
android/key.properties
**/*.jks
**/*.keystore
**/*.p12
**/*.p8
**/*.mobileprovision
ios/Runner/GoogleService-Info.plist
play-store-key.json
*.env

# Platform folders are generated by `flutter create .`; uncomment to ignore
# if you prefer not to commit them.
# /android/
# /ios/
# /macos/
# /linux/
# /windows/
# /web/
